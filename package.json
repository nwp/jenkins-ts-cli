{
  "name": "jenkins-ts-cli",
  "version": "0.1.0",
  "description": "TypeScript CLI client for Jenkins, built with Bun",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "jenkins": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile src/index.ts --outfile jenkins",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
